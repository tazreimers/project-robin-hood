# Postgres connection used by the API and worker containers.
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/arbitrage

# Redis broker/result backend used by Celery.
REDIS_URL=redis://redis:6379/0

# Optional for local demo mode. Set a real key only in your private .env file.
ODDS_API_KEY=

# Comma-separated The Odds API sport keys or local aliases. Defaults target Australian sports.
SPORT_KEYS=afl,nrl

# Comma-separated The Odds API regions. "au" keeps local scans small.
ODDS_REGIONS=au

# Featured markets fetched from /v4/sports/{sport}/odds.
# Supported here by The Odds API: h2h,spreads,totals,outrights.
# The app currently detects arbitrage only from h2h snapshots; other markets are ingested for review/future workflows.
ODDS_MARKETS=h2h

# Additional event-level markets fetched one event at a time from /events/{eventId}/odds.
# Use this for player props and period markets, for example AFL:
# player_disposals_over,player_goal_scorer_anytime,player_marks_over
ODDS_EVENT_MARKETS=

# Maximum upcoming events per sport to query for ODDS_EVENT_MARKETS on each scan. Set 0 to disable.
# Event-level markets cost provider credits per event, region, and returned market.
ODDS_EVENT_MARKET_MAX_EVENTS=8

# Stake pool used when sizing arbitrage legs.
DEFAULT_TOTAL_STAKE=1000

# Minimum arbitrage margin required before saving an opportunity.
MIN_ARBITRAGE_MARGIN=0.01

# Maximum odds age accepted by validation and market quality checks.
MAX_ODDS_AGE_SECONDS=60

# Daily provider request budget used by the quota guard.
DAILY_QUOTA_BUDGET=500

# Provider credits to preserve after estimated scan cost.
MIN_REQUESTS_REMAINING_BUFFER=20

# Maximum manual or scheduled scans allowed per rolling hour.
MAX_SCANS_PER_HOUR=12

# Enable or disable quota protection. Keep true for normal development.
ENABLE_QUOTA_GUARD=true

# Adaptive polling cadence for low-priority events.
LOW_PRIORITY_SCAN_MINUTES=30

# Adaptive polling cadence for normal-priority events.
NORMAL_PRIORITY_SCAN_MINUTES=5

# Adaptive polling cadence for high-priority events.
HIGH_PRIORITY_SCAN_SECONDS=60

# Adaptive polling cadence for urgent events.
URGENT_PRIORITY_SCAN_SECONDS=30

# Distance from arbitrage where an event becomes urgent.
NEAR_ARB_THRESHOLD=0.03

# Minimum market quality confidence required before saving opportunities.
MIN_MARKET_CONFIDENCE=0.85

# Maximum allowed event start-time disagreement across provider/bookmaker data.
MAX_EVENT_START_TIME_DIFF_MINUTES=5
